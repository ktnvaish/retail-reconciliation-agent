# Keep the build context (and final image) small and reproducible.
.git
.gitignore
.github

# Python caches / envs
__pycache__/
*.py[cod]
.venv/
venv/
.uv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# Secrets — never bake into the image
.env
.env.*
!.env.example

# Runtime + dev-only artifacts
data/runtime/*
!data/runtime/.gitkeep
tests/
docs/
*.md
!README.md

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
