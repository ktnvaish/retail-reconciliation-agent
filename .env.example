# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for local development.
# NEVER commit a real `.env`. On Azure Container Apps these become secrets/env.
# ---------------------------------------------------------------------------

# --- LLM (Groq) ---------------------------------------------------------------
GROQ_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.3-70b-versatile
# true -> canned, schema-valid LLM responses; lets the full pipeline run offline.
MOCK_LLM=true
# Per-run cap on LLM calls (planner/classify are cached by mismatch_key).
MAX_LLM_CALLS=200

# --- Notifier provider: resend | smtp | mock ---------------------------------
# local/tests default = mock; hosted Azure demo = resend (real delivery).
NOTIFIER=mock

# --- Resend (used when NOTIFIER=resend) --------------------------------------
RESEND_API_KEY=re_your_key_here
RESEND_FROM=alerts@yourdomain.com

# --- SMTP (used when NOTIFIER=smtp; Gmail App Password) -----------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com

# --- Application --------------------------------------------------------------
# Single writable directory for all runtime state (SQLite, incidents, outbox).
DATA_DIR=data/runtime
DATABASE_URL=sqlite:///data/runtime/reconcile.db
LOG_LEVEL=INFO
# The web server binds 0.0.0.0:$PORT. Azure injects this automatically.
PORT=8000

# --- Hosted-demo hardening (optional) ----------------------------------------
# If set, POST /reconcile requires this key (header X-Demo-Key or form field).
DEMO_ACCESS_KEY=

# --- Recipient overrides (optional) ------------------------------------------
# Precedence over config/settings.yaml, so real demo inboxes can be set per
# deployment without committing personal addresses to a public repo.
RECIPIENT_STORE_MANAGER=
RECIPIENT_ADMIN=
RECIPIENT_BANK=
RECIPIENT_PG_RAZORPAY=
RECIPIENT_PG_PAYU=
RECIPIENT_PG_CASHFREE=

# --- Optional tracing (LangSmith) --------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=reconcileflow
LANGSMITH_TRACING=false
