# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- uv ---
# uv.lock IS committed (reproducible installs); the cache/venv are not.
.uv/

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- Secrets / environment ---
.env
.env.*
!.env.example

# --- Runtime data (generated; keep the folder, ignore contents) ---
data/runtime/*
!data/runtime/.gitkeep

# --- IDE / OS ---
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
.DS_Store
Thumbs.db
